generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Board {
  id              String    @id @default(uuid())
  name            String
  createdDtUtc    DateTime  @map("created_dt_utc")
  lastUpdatedDtUtc DateTime? @map("last_updated_dt_utc")
  columns         Column[]

  @@map("boards")
}

model Column {
  id              String    @id @default(uuid())
  boardId         String    @map("board_id")
  name            String
  sequence        Int
  createdDtUtc    DateTime  @map("created_dt_utc")
  lastUpdatedDtUtc DateTime? @map("last_updated_dt_utc")
  board           Board     @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards           Card[]

  @@unique([boardId, sequence])
  @@map("columns")
}

model Card {
  id              String    @id @default(uuid())
  columnId        String    @map("column_id")
  name            String
  description     String?
  sequence        Int
  createdDtUtc    DateTime  @map("created_dt_utc")
  lastUpdatedDtUtc DateTime? @map("last_updated_dt_utc")
  column          Column    @relation(fields: [columnId], references: [id], onDelete: Cascade)

  @@unique([columnId, sequence])
  @@map("cards")
}